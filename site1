<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>TraceTree 轨迹树</title>
<style>
:root{
    --bg:#f7f7f4;
    --paper:#ffffff;
    --text:#20241f;
    --muted:#747a72;
    --line:#cfd6cc;
    --green:#2f8f5b;
    --gray:#9a9a9a;
    --red:#c9483b;
    --dark:#1f2522;
    --shadow:0 18px 50px rgba(20,35,25,0.08);
    --radius:24px;
}
*{
    box-sizing:border-box;
    margin:0;
    padding:0;
}
html{
    scroll-behavior:smooth;
}
body{
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Noto Sans SC",sans-serif;
    background:var(--bg);
    color:var(--text);
    line-height:1.6;
}
button{
    border:none;
    background:var(--dark);
    color:white;
    padding:11px 18px;
    border-radius:999px;
    cursor:pointer;
    font-size:14px;
}
button:hover{
    opacity:0.92;
}
button.secondary{
    background:#edf0ea;
    color:var(--dark);
}
button.danger{
    background:var(--red);
}
a{
    color:inherit;
    text-decoration:none;
}
/* HOME */
.home{
    min-height:100vh;
    padding:28px;
    display:flex;
    flex-direction:column;
}
.nav{
    max-width:1180px;
    width:100%;
    margin:0 auto;
    display:flex;
    justify-content:space-between;
    align-items:center;
}
.logo{
    font-weight:700;
    font-size:18px;
}
.nav a{
    font-size:14px;
    color:var(--muted);
}
.hero{
    flex:1;
    max-width:1180px;
    width:100%;
    margin:0 auto;
    display:grid;
    grid-template-columns:0.9fr 1.1fr;
    gap:42px;
    align-items:center;
}
.hero-text h1{
    font-size:clamp(44px,7vw,86px);
    line-height:1;
    letter-spacing:-3px;
    margin-bottom:20px;
}
.hero-text p{
    font-size:18px;
    color:var(--muted);
    max-width:460px;
    margin-bottom:24px;
}
.tree-symbol{
    position:relative;
    height:620px;
    background:var(--paper);
    border-radius:36px;
    box-shadow:var(--shadow);
    border:1px solid #e8ece4;
    overflow:hidden;
}
/* Rooted symbolic tree: only edges and vertices */
.svg-tree{
    width:100%;
    height:100%;
}
.edge{
    stroke:var(--line);
    stroke-width:3;
    fill:none;
}
.vertex{
    stroke:white;
    stroke-width:4;
}
.root{
    fill:var(--dark);
}
.verified{
    fill:var(--green);
}
.unverified{
    fill:var(--gray);
}
.infringe{
    fill:var(--red);
}
.scroll-note{
    text-align:center;
    color:var(--muted);
    font-size:13px;
    padding-bottom:18px;
}
/* GUIDELINES */
.guidelines{
    max-width:1180px;
    margin:0 auto;
    padding:80px 28px 30px;
}
.guideline-box{
    background:var(--paper);
    border-radius:var(--radius);
    box-shadow:var(--shadow);
    border:1px solid #e8ece4;
    padding:28px;
}
.guideline-box h2{
    font-size:26px;
    margin-bottom:22px;
}
.guideline-grid{
    display:grid;
    grid-template-columns:repeat(4,minmax(0,1fr));
    gap:16px;
}
.guide{
    border:1px solid #ecefe8;
    border-radius:18px;
    padding:18px;
    background:#fbfcfa;
}
.guide strong{
    display:block;
    margin-bottom:8px;
    font-size:15px;
}
.guide p{
    color:var(--muted);
    font-size:14px;
}
/* EDITOR */
.editor{
    max-width:1180px;
    margin:0 auto;
    padding:90px 28px 60px;
}
.section-head{
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    gap:20px;
    flex-wrap:wrap;
    margin-bottom:26px;
}
.section-head h2{
    font-size:34px;
    letter-spacing:-1px;
}
.section-head p{
    color:var(--muted);
    max-width:680px;
}
.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:18px;
    margin-bottom:24px;
}
.card,
.tree-panel{
    background:var(--paper);
    border-radius:var(--radius);
    padding:22px;
    box-shadow:var(--shadow);
    border:1px solid #e8ece4;
}
.card h3{
    font-size:19px;
    margin-bottom:10px;
}
.card p{
    color:var(--muted);
    font-size:14px;
    margin-bottom:14px;
}
input,
textarea{
    width:100%;
    padding:12px 13px;
    border:1px solid #d8ddd4;
    border-radius:13px;
    margin-bottom:12px;
    font-size:14px;
    outline:none;
}
input:focus,
textarea:focus{
    border-color:var(--green);
}
textarea{
    resize:vertical;
    min-height:88px;
}
.tree-title{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:12px;
    flex-wrap:wrap;
    margin-bottom:24px;
}
.legend{
    display:flex;
    gap:12px;
    flex-wrap:wrap;
    color:var(--muted);
    font-size:13px;
}
.legend span{
    display:flex;
    align-items:center;
    gap:6px;
}
.legend i{
    width:10px;
    height:10px;
    display:inline-block;
    border-radius:50%;
}
.i-green{background:var(--green);}
.i-gray{background:var(--gray);}
.i-red{background:var(--red);}
.trace-tree{
    display:flex;
    flex-direction:column;
    gap:24px;
}
.node{
    position:relative;
    padding-left:36px;
}
.node::before{
    content:"";
    position:absolute;
    left:12px;
    top:0;
    width:2px;
    height:100%;
    background:var(--line);
}
.node:last-child::before{
    height:28px;
}
.dot{
    position:absolute;
    left:0;
    top:8px;
    width:24px;
    height:24px;
    border-radius:50%;
    border:3px solid white;
    box-shadow:0 0 0 1px rgba(0,0,0,0.08);
}
.node.verified .dot{background:var(--green);}
.node.unverified .dot{background:var(--gray);}
.node.infringe .dot{background:var(--red);}
.node-card{
    background:#fafbf8;
    border:1px solid #e9ede5;
    border-radius:18px;
    padding:18px;
}
.node-top{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:12px;
    flex-wrap:wrap;
    margin-bottom:8px;
}
.badge{
    padding:5px 10px;
    border-radius:999px;
    font-size:12px;
    font-weight:700;
}
.badge.verified{
    background:#e8f5ee;
    color:var(--green);
}
.badge.unverified{
    background:#eeeeee;
    color:#666;
}
.badge.infringe{
    background:#fbeceb;
    color:var(--red);
}
.meta{
    color:var(--muted);
    font-size:13px;
    margin-bottom:8px;
}
.node-link{
    display:inline-block;
    color:#276ed8;
    word-break:break-all;
    font-size:14px;
    margin-bottom:12px;
}
.actions{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    align-items:center;
}
.vote{
    color:var(--muted);
    font-size:14px;
}
.footer{
    text-align:center;
    color:var(--muted);
    font-size:14px;
    padding:42px 20px 58px;
}
@media(max-width:900px){
    .hero{
        grid-template-columns:1fr;
        padding-top:60px;
    }
    .tree-symbol{
        height:500px;
    }
    .guideline-grid{
        grid-template-columns:1fr 1fr;
    }
}
@media(max-width:620px){
    .home{
        padding:22px;
    }
    .hero-text h1{
        font-size:44px;
        letter-spacing:-1.6px;
    }
    .tree-symbol{
        height:420px;
    }
    .guideline-grid{
        grid-template-columns:1fr;
    }
    .section-head h2{
        font-size:28px;
    }
}
</style>
</head>
<body>
<section class="home" id="home">
    <nav class="nav">
        <div class="logo">TraceTree</div>
        <a href="#editor">Edit Tree</a>
    </nav>
    <div class="hero">
        <div class="hero-text">
            <h1>Trace<br>the<br>Original.</h1>
            <p>Verified paths for creative work.</p>
            <a href="#guidelines">
                <button>View Guidelines</button>
            </a>
        </div>
        <div class="tree-symbol" aria-label="symbolic rooted tree">
            <svg class="svg-tree" viewBox="0 0 700 620" preserveAspectRatio="xMidYMid meet">
                <!-- edges -->
                <path class="edge" d="M350 530 L350 410" />
                <path class="edge" d="M350 410 L220 300" />
                <path class="edge" d="M350 410 L350 270" />
                <path class="edge" d="M350 410 L480 300" />
                <path class="edge" d="M220 300 L135 190" />
                <path class="edge" d="M220 300 L265 170" />
                <path class="edge" d="M350 270 L350 125" />
                <path class="edge" d="M480 300 L435 170" />
                <path class="edge" d="M480 300 L565 190" />
                <!-- vertices -->
                <circle class="vertex root" cx="350" cy="530" r="22" />
                <circle class="vertex verified" cx="350" cy="410" r="17" />
                <circle class="vertex verified" cx="220" cy="300" r="17" />
                <circle class="vertex verified" cx="350" cy="270" r="17" />
                <circle class="vertex unverified" cx="480" cy="300" r="17" />
                <circle class="vertex verified" cx="135" cy="190" r="15" />
                <circle class="vertex unverified" cx="265" cy="170" r="15" />
                <circle class="vertex verified" cx="350" cy="125" r="15" />
                <circle class="vertex unverified" cx="435" cy="170" r="15" />
                <circle class="vertex infringe" cx="565" cy="190" r="15" />
            </svg>
        </div>
    </div>
    <div class="scroll-note">Scroll ↓</div>
</section>
<section class="guidelines" id="guidelines">
    <div class="guideline-box">
        <h2>User Guidelines</h2>
        <div class="guideline-grid">
            <div class="guide">
                <strong>1. Create Root</strong>
                <p>Creator verifies identity and registers the original work.</p>
            </div>
            <div class="guide">
                <strong>2. Request License</strong>
                <p>Reposter submits ID, platform, link, and planned edits.</p>
            </div>
            <div class="guide">
                <strong>3. Add Clue</strong>
                <p>Anyone may submit a suspected repost as a gray node.</p>
            </div>
            <div class="guide">
                <strong>4. Review / Report</strong>
                <p>Creator marks nodes as authorized, infringing, or false.</p>
            </div>
        </div>
    </div>
</section>
<section class="editor" id="editor">
    <div class="section-head">
        <div>
            <h2>Edit a Trace Tree</h2>
            <p>Create a root node, add authorized reposts, add clues, and review suspicious nodes.</p>
        </div>
        <a href="#home">
            <button class="secondary">Back to Top</button>
        </a>
    </div>
    <div class="grid">
        <div class="card">
            <h3>Create Root</h3>
            <p>The original creator creates the base node.</p>
            <input type="text" placeholder="Work title" id="workTitle">
            <input type="url" placeholder="Original link" id="originalLink">
            <input type="text" placeholder="Creator ID" id="authorId">
            <textarea placeholder="Proof / timestamp / fingerprint" id="fingerprint"></textarea>
            <button onclick="createRoot()">Create Root</button>
        </div>
        <div class="card">
            <h3>Authorize Repost</h3>
            <p>Approved reposts become green nodes.</p>
            <input type="text" placeholder="Reposter ID" id="reposterId">
            <input type="url" placeholder="Repost link" id="repostLink">
            <textarea placeholder="Planned edits" id="editPlan"></textarea>
            <button onclick="addVerifiedNode()">Approve</button>
        </div>
        <div class="card">
            <h3>Add Clue</h3>
            <p>Unverified clues become gray nodes.</p>
            <input type="text" placeholder="Finder ID" id="finderId">
            <input type="url" placeholder="Suspicious link" id="clueLink">
            <textarea placeholder="Note" id="clueNote"></textarea>
            <button onclick="addUnverifiedNode()">Add Clue</button>
        </div>
    </div>
    <div class="tree-panel">
        <div class="tree-title">
            <div>
                <h3 id="treeName">Trace Tree Demo</h3>
                <div class="legend">
                    <span><i class="i-green"></i> Verified</span>
                    <span><i class="i-gray"></i> Unverified</span>
                    <span><i class="i-red"></i> Infringing</span>
                </div>
            </div>
            <button class="secondary" onclick="exportReport()">Export Report</button>
        </div>
        <div class="trace-tree" id="tree">
            <div class="node verified">
                <div class="dot"></div>
                <div class="node-card">
                    <div class="node-top">
                        <strong>Original Work</strong>
                        <span class="badge verified">Root</span>
                    </div>
                    <div class="meta">Creator: @OriginalCreator · 2026-05-20</div>
                    <a class="node-link" href="https://example.com/original" target="_blank">
                        https://example.com/original
                    </a>
                    <div class="actions">
                        <button class="secondary">Proof</button>
                    </div>
                </div>
            </div>
            <div class="node verified">
                <div class="dot"></div>
                <div class="node-card">
                    <div class="node-top">
                        <strong>Authorized Repost</strong>
                        <span class="badge verified">Verified</span>
                    </div>
                    <div class="meta">Reposter: @MathChannel · 2026-05-21</div>
                    <a class="node-link" href="https://example.com/repost" target="_blank">
                        https://example.com/repost
                    </a>
                    <div class="actions">
                        <button class="secondary">License</button>
                    </div>
                </div>
            </div>
            <div class="node unverified">
                <div class="dot"></div>
                <div class="node-card">
                    <div class="node-top">
                        <strong>Community Clue</strong>
                        <span class="badge unverified">Unverified</span>
                    </div>
                    <div class="meta">Finder: @CommunityUser · 2026-05-22</div>
                    <a class="node-link" href="https://example.com/suspected" target="_blank">
                        https://example.com/suspected
                    </a>
                    <div class="actions">
                        <button onclick="verifyNode(this)">Authorize</button>
                        <button class="danger" onclick="markInfringe(this)">Infringe</button>
                        <button class="secondary" onclick="dismissNode(this)">Dismiss</button>
                        <div class="vote">Votes: 43</div>
                    </div>
                </div>
            </div>
            <div class="node infringe">
                <div class="dot"></div>
                <div class="node-card">
                    <div class="node-top">
                        <strong>Infringing Copy</strong>
                        <span class="badge infringe">Infringing</span>
                    </div>
                    <div class="meta">Confirmed · 2026-05-23</div>
                    <a class="node-link" href="https://example.com/pirated" target="_blank">
                        https://example.com/pirated
                    </a>
                    <div class="actions">
                        <button class="danger" onclick="reportNode()">Report</button>
                        <div class="vote">Votes: 301</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<div class="footer">
    TraceTree Prototype
</div>
<script>
function safeText(value, fallback){
    const clean = String(value || "").trim();
    return clean.length > 0 ? clean : fallback;
}
function safeUrl(value, fallback){
    const clean = String(value || "").trim();
    if(clean.startsWith("http://") || clean.startsWith("https://")){
        return clean;
    }
    return fallback;
}
function today(){
    return new Date().toISOString().slice(0,10);
}
function createRoot(){
    const title = safeText(document.getElementById("workTitle").value, "");
    const author = safeText(document.getElementById("authorId").value, "@OriginalCreator");
    const link = safeUrl(document.getElementById("originalLink").value, "https://example.com/original");
    if(!title){
        alert("Please enter a work title.");
        return;
    }
    document.getElementById("treeName").innerText = title;
    const tree = document.getElementById("tree");
    tree.innerHTML = `
        <div class="node verified">
            <div class="dot"></div>
            <div class="node-card">
                <div class="node-top">
                    <strong>Original Work</strong>
                    <span class="badge verified">Root</span>
                </div>
                <div class="meta">Creator: ${author} · ${today()}</div>
                <a class="node-link" href="${link}" target="_blank">
                    ${link}
                </a>
                <div class="actions">
                    <button class="secondary">Proof</button>
                </div>
            </div>
        </div>
    `;
}
function addVerifiedNode(){
    const reposter = safeText(document.getElementById("reposterId").value, "@AuthorizedReposter");
    const link = safeUrl(document.getElementById("repostLink").value, "https://example.com/authorized-repost");
    const tree = document.getElementById("tree");
    const node = document.createElement("div");
    node.className = "node verified";
    node.innerHTML = `
        <div class="dot"></div>
        <div class="node-card">
            <div class="node-top">
                <strong>Authorized Repost</strong>
                <span class="badge verified">Verified</span>
            </div>
            <div class="meta">Reposter: ${reposter} · ${today()}</div>
            <a class="node-link" href="${link}" target="_blank">
                ${link}
            </a>
            <div class="actions">
                <button class="secondary">License</button>
            </div>
        </div>
    `;
    tree.appendChild(node);
}
function addUnverifiedNode(){
    const finder = safeText(document.getElementById("finderId").value, "@CommunityUser");
    const link = safeUrl(document.getElementById("clueLink").value, "https://example.com/suspected-repost");
    const tree = document.getElementById("tree");
    const node = document.createElement("div");
    node.className = "node unverified";
    node.innerHTML = `
        <div class="dot"></div>
        <div class="node-card">
            <div class="node-top">
                <strong>Community Clue</strong>
                <span class="badge unverified">Unverified</span>
            </div>
            <div class="meta">Finder: ${finder} · ${today()}</div>
            <a class="node-link" href="${link}" target="_blank">
                ${link}
            </a>
            <div class="actions">
                <button onclick="verifyNode(this)">Authorize</button>
                <button class="danger" onclick="markInfringe(this)">Infringe</button>
                <button class="secondary" onclick="dismissNode(this)">Dismiss</button>
                <div class="vote">Votes: 0</div>
            </div>
        </div>
    `;
    tree.appendChild(node);
}
function verifyNode(button){
    const node = button.closest(".node");
    node.classList.remove("unverified","infringe");
    node.classList.add("verified");
    const badge = node.querySelector(".badge");
    badge.className = "badge verified";
    badge.innerText = "Verified";
    node.querySelector(".node-top strong").innerText = "Authorized Repost";
}
function markInfringe(button){
    const node = button.closest(".node");
    node.classList.remove("unverified","verified");
    node.classList.add("infringe");
    const badge = node.querySelector(".badge");
    badge.className = "badge infringe";
    badge.innerText = "Infringing";
    node.querySelector(".node-top strong").innerText = "Infringing Copy";
    const actions = node.querySelector(".actions");
    if(!actions.querySelector(".report-btn")){
        const report = document.createElement("button");
        report.className = "danger report-btn";
        report.innerText = "Report";
        report.onclick = reportNode;
        actions.prepend(report);
    }
}
function dismissNode(button){
    button.closest(".node").remove();
}
function reportNode(){
    alert("Report package generated.");
}
function exportReport(){
    alert("Report package exported.");
}
</script>
</body>
</html>